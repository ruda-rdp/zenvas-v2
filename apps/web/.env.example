# ─────────────────────────────────────────────────────────────────────────────
# Zenvas Environment Configuration
# Copy this file to .env and fill in the actual values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# Database - Neon PostgreSQL (or your preferred PostgreSQL provider)
# Get connection string from Neon dashboard: https://neon.tech
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# NextAuth.js Authentication
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Odoo Integration (ADR-0001)
# Self-hosted Odoo instance configuration
# URL: Your Odoo instance URL (e.g., https://odoo.example.com)
ODOO_URL="https://your-odoo-domain.com"
# Database name as shown in Odoo Apps
ODOO_DB="your-odoo-database"
# Username for API access (recommend creating dedicated API user)
ODOO_USERNAME="api_user@example.com"
# API Key from Odoo: Settings > User > API Keys
ODOO_API_KEY="your-odoo-api-key"

# Brand Domains (ADR-0003)
# Internal domain for the Zenvas platform
INTERNAL_DOMAIN="localhost"
# Alternative internal domain (for staging/production)
INTERNAL_DOMAIN_ALT="app2.zenvas.com"
# Free subdomain suffix for user-created brands
# Users will get: {brandname}.zenvas-portal.app
FREE_SUBDOMAIN_SUFFIX="zenvas-portal.app"

# Super Admin (SaaS Platform Owner)
# Set the email of the super admin who can access /superadmin
# This user can view and manage all organizations, brands, and users
SUPERADMIN_EMAIL="your-superadmin@email.com"
NEXT_PUBLIC_SUPERADMIN_EMAIL="your-superadmin@email.com"
